{
  "name": "@cortexkit/aft-opencode",
  "version": "0.13.0",
  "type": "module",
  "description": "OpenCode plugin for Agent File Tools (AFT) — tree-sitter and lsp powered code analysis",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aft-opencode": "dist/cli.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cortexkit/aft"
  },
  "files": [
    "dist",
    "src/tui",
    "src/shared",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin && bun build src/tui/index.tsx --outfile dist/tui.js --target bun --format esm --external @opencode-ai/plugin --external @opencode-ai/plugin/tui --external @opentui/solid --external solid-js && bun build src/cli/index.ts --outfile dist/cli.js --target node --format esm && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "pretest": "cd ../.. && cargo build",
    "test": "bun test",
    "test:e2e": "bun test src/__tests__/e2e/",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@opencode-ai/plugin": "^1.2.26",
    "@opencode-ai/sdk": "^1.2.26",
    "comment-json": "^4.6.2",
    "zod": "^4.1.8"
  },
  "optionalDependencies": {
    "@cortexkit/aft-darwin-arm64": "0.13.0",
    "@cortexkit/aft-darwin-x64": "0.13.0",
    "@cortexkit/aft-linux-arm64": "0.13.0",
    "@cortexkit/aft-linux-x64": "0.13.0",
    "@cortexkit/aft-win32-x64": "0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./src/tui/index.tsx",
      "import": "./src/tui/index.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0"
  }
}
